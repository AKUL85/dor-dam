# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=*

# ── Logging ──────────────────────────────────────────────────
# error | warn | info | debug
LOG_LEVEL=info
# Emit single-line JSON logs (recommended in production)
LOG_JSON=false

# ── Database (optional) ──────────────────────────────────────
# When unset, scraping still works but DB persistence is disabled.
DATABASE_URL=postgresql://user:password@localhost:5432/dordam

# ── Scraper ──────────────────────────────────────────────────
SCRAPER_HEADLESS=true
SCRAPER_DELAY_MS=2000
SCRAPER_MAX_PAGES=15
SCRAPER_NAV_TIMEOUT_MS=45000
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BASE_DELAY_MS=1000
SCRAPER_SAVE_TO_DISK=true
SCRAPER_OUTPUT_DIR=./output
SCRAPER_USER_AGENT=PhoneAdvisorBD-Bot/1.0 (+https://phoneadvisor.com.bd/bot)
